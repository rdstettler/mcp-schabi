# Multi-child example (recommended)
SCHABI_CHILDREN="Emma,Lucas"

# Child 1
SCHABI_EMMA_USERNAME=your_child_username_or_email
SCHABI_EMMA_PASSWORD=your_child_password
SCHABI_EMMA_SCHOOLCLASS=24088

# Child 2
SCHABI_LUCAS_USERNAME=your_other_child_username_or_email
SCHABI_LUCAS_PASSWORD=your_other_child_password
SCHABI_LUCAS_SCHOOLCLASS=24089

# Legacy single-child fallback (if SCHABI_CHILDREN is not set)
# SCHABI_USERNAME=...
# SCHABI_PASSWORD=...
# SCHABI_SCHOOLCLASS=...
